# Todoist API
TODOIST_API_TOKEN=your-todoist-api-token

# AI Models
OPENAI_API_KEY=your-openai-api-key
OPENROUTER_API_KEY=  # Optional fallback
MODEL_PROVIDER=openai  # openai or openrouter
MODEL_NAME=gpt-4o-mini  # gpt-4o-mini, gpt-4o, gpt-3.5-turbo, etc.
# Note: To use GPT-5.4 nano when available, set MODEL_NAME=gpt-5.4-nano

# WhatsApp (Baileys - free self-hosted)
WHATSAPP_SESSION_PATH=./auth  # Persisted WhatsApp auth session

# Redis (optional - for conversation context)
REDIS_URL=redis://localhost:6379