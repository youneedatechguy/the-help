# ⚠️ REQUIRED ENVIRONMENT VARIABLES - SET THESE FIRST
TODOIST_API_TOKEN=your-todoist-api-token-here
OPENAI_API_KEY=your-openai-api-key-here
WHATSAPP_SESSION_PATH=/app/auth

# 🔧 OPTIONAL CONFIGURATION
OPENROUTER_API_KEY=  # Optional fallback
MODEL_PROVIDER=openai  # openai or openrouter
MODEL_NAME=gpt-4o-mini  # gpt-4o-mini, gpt-4o, gpt-3.5-turbo, etc.

# Redis (optional - for conversation context)
REDIS_URL=redis://localhost:6379

# Legacy: NBN Telegram Bot (if running alongside)
IPERIUM_EMAIL=your-email@example.com
IPERIUM_PASSWORD=your-password
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token